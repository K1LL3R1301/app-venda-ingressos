generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum EventCollection {
  FESTAS_SHOWS
  TEATROS_ESPETACULOS
  STAND_UP_COMEDY
  ESPORTES
  PASSEIOS_TOURS
  CONGRESSOS
  INFANTIL
  GASTRONOMIA
}

model Organizer {
  id        String  @id @default(uuid())
  tradeName String
  legalName String?
  document  String? @unique
  email     String?
  phone     String?
  status    String  @default("ACTIVE")

  slug         String? @unique
  bio          String?
  websiteUrl   String?
  instagramUrl String?
  facebookUrl  String?
  youtubeUrl   String?
  whatsapp     String?
  logoUrl      String?
  bannerUrl    String?
  city         String?
  state        String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  events         Event[]
  supportThreads SupportThread[]
}

model Event {
  id          String @id @default(uuid())
  organizerId String

  name        String
  description String?
  eventDate   DateTime
  capacity    Int
  status      String   @default("DRAFT")

  slug             String?          @unique
  shortDescription String?
  category         EventCollection?
  visibility       String           @default("PUBLIC")
  timezone         String           @default("America/Sao_Paulo")
  startDate        DateTime?
  endDate          DateTime?
  saleStartAt      DateTime?
  saleEndAt        DateTime?
  featured         Boolean          @default(false)
  highlightTag     String?
  checkoutTitle    String?
  checkoutSubtitle String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organizer      Organizer       @relation(fields: [organizerId], references: [id])
  ticketTypes    TicketType[]
  orders         Order[]
  supportThreads SupportThread[]

  content  EventContent?
  location EventLocation?
  media    EventMedia?
  policy   EventPolicy?
}

model EventContent {
  id      String @id @default(uuid())
  eventId String @unique

  headline             String?
  summary              String?
  fullDescription      String?
  attractions          String?
  schedule             String?
  sectorDetails        String?
  importantInfo        String?
  faq                  String?
  producerDescription  String?
  purchaseInstructions String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@index([eventId])
}

model EventLocation {
  id      String @id @default(uuid())
  eventId String @unique

  mode         String   @default("PRESENTIAL")
  venueName    String?
  addressLine1 String?
  addressLine2 String?
  neighborhood String?
  city         String?
  state        String?
  zipCode      String?
  reference    String?
  mapUrl       String?
  instructions String?
  latitude     Decimal? @db.Decimal(10, 7)
  longitude    Decimal? @db.Decimal(10, 7)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@index([eventId])
  @@index([city, state])
}

model EventMedia {
  id      String @id @default(uuid())
  eventId String @unique

  coverImageUrl     String?
  bannerImageUrl    String?
  thumbnailUrl      String?
  mobileBannerUrl   String?
  sectorMapImageUrl String?
  gallery           Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@index([eventId])
}

model EventPolicy {
  id      String @id @default(uuid())
  eventId String @unique

  ageRating       String?
  refundPolicy    String?
  halfEntryPolicy String?
  transferPolicy  String?
  termsNotes      String?
  entryRules      String?
  documentRules   String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@index([eventId])
}

model TicketType {
  id          String  @id @default(uuid())
  eventId     String
  name        String
  description String?
  price       Decimal @db.Decimal(10, 2)
  quantity    Int
  status      String  @default("ACTIVE")

  lotLabel           String?
  salesStartAt       DateTime?
  salesEndAt         DateTime?
  minPerOrder        Int       @default(1)
  maxPerOrder        Int?
  displayOrder       Int       @default(0)
  feeAmount          Decimal?  @db.Decimal(10, 2)
  feeDescription     String?
  benefitDescription String?
  isHidden           Boolean   @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  event      Event       @relation(fields: [eventId], references: [id])
  orderItems OrderItem[]

  @@index([eventId])
  @@index([status])
  @@index([displayOrder])
}

model Order {
  id             String   @id @default(uuid())
  eventId        String
  customerUserId String?
  customerName   String
  customerEmail  String
  customerCpf    String?
  status         String   @default("PENDING")
  totalAmount    Decimal  @db.Decimal(10, 2)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  event            Event                   @relation(fields: [eventId], references: [id])
  customerUser     User?                   @relation("OrderCustomerUser", fields: [customerUserId], references: [id])
  items            OrderItem[]
  payments         Payment[]
  cancellations    TicketCancellation[]
  supportThreads   SupportThread[]
  transferRequests TicketTransferRequest[]

  @@index([eventId])
  @@index([customerUserId])
  @@index([customerEmail])
  @@index([customerCpf])
}

model OrderItem {
  id           String   @id @default(uuid())
  orderId      String
  ticketTypeId String
  quantity     Int
  unitPrice    Decimal  @db.Decimal(10, 2)
  totalPrice   Decimal  @db.Decimal(10, 2)
  createdAt    DateTime @default(now())

  order      Order      @relation(fields: [orderId], references: [id])
  ticketType TicketType @relation(fields: [ticketTypeId], references: [id])
  tickets    Ticket[]

  @@index([orderId])
  @@index([ticketTypeId])
}

model Ticket {
  id                 String    @id @default(uuid())
  orderItemId        String
  currentOwnerUserId String?
  code               String    @unique
  status             String    @default("AVAILABLE")
  holderName         String?
  holderEmail        String?
  holderCpf          String?
  usedAt             DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  orderItem        OrderItem               @relation(fields: [orderItemId], references: [id])
  currentOwnerUser User?                   @relation("TicketCurrentOwner", fields: [currentOwnerUserId], references: [id])
  checkins         Checkin[]
  cancellations    TicketCancellation[]
  transferRequests TicketTransferRequest[]

  @@index([orderItemId])
  @@index([currentOwnerUserId])
  @@index([holderEmail])
  @@index([holderCpf])
}

model TicketTransferRequest {
  id                String @id @default(uuid())
  ticketId          String
  orderId           String
  requestedByUserId String
  fromUserId        String
  toUserId          String

  requestedByName  String?
  requestedByEmail String?
  requestedByCpf   String?
  fromName         String?
  fromEmail        String?
  fromCpf          String?
  toName           String?
  toEmail          String?
  toCpf            String?

  status         String   @default("PENDING_PAYMENT")
  responseReason String?
  requestedAt    DateTime @default(now())
  respondedAt    DateTime?
  expiresAt      DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  ticket          Ticket @relation(fields: [ticketId], references: [id])
  order           Order  @relation(fields: [orderId], references: [id])
  requestedByUser User   @relation("TicketTransferRequestedByUser", fields: [requestedByUserId], references: [id])
  fromUser        User   @relation("TicketTransferFromUser", fields: [fromUserId], references: [id])
  toUser          User   @relation("TicketTransferToUser", fields: [toUserId], references: [id])

  @@index([ticketId])
  @@index([orderId])
  @@index([requestedByUserId])
  @@index([fromUserId])
  @@index([toUserId])
  @@index([status])
  @@index([requestedAt])
  @@index([respondedAt])
}

model Checkin {
  id           String   @id @default(uuid())
  ticketId     String
  checkedAt    DateTime @default(now())
  gate         String?
  operatorName String?
  createdAt    DateTime @default(now())

  ticket Ticket @relation(fields: [ticketId], references: [id])

  @@index([ticketId])
}

model Payment {
  id        String   @id @default(uuid())
  orderId   String
  amount    Decimal  @db.Decimal(10, 2)
  method    String
  status    String   @default("PENDING")
  paidAt    DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  order Order @relation(fields: [orderId], references: [id])

  @@index([orderId])
}

model User {
  id              String   @id @default(uuid())
  name            String
  email           String   @unique
  passwordHash    String?
  cpf             String?
  cpfNormalized   String?  @unique
  googleId        String?  @unique
  avatarUrl       String?
  authProvider    String   @default("PASSWORD")
  role            String   @default("ADMIN")
  status          String   @default("ACTIVE")
  emailVerifiedAt DateTime?
  cpfVerifiedAt   DateTime?
  lastLoginAt     DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  orders                   Order[]         @relation("OrderCustomerUser")
  ownedTickets             Ticket[]        @relation("TicketCurrentOwner")
  supportThreadsAsCustomer SupportThread[] @relation("SupportThreadCustomerUser")

  requestedTicketTransfers TicketTransferRequest[] @relation("TicketTransferRequestedByUser")
  outgoingTicketTransfers  TicketTransferRequest[] @relation("TicketTransferFromUser")
  incomingTicketTransfers  TicketTransferRequest[] @relation("TicketTransferToUser")

  walletTransactions  WalletTransaction[]
  ticketCancellations TicketCancellation[]

  sentMessages    SupportMessage[] @relation("SupportMessageSender")
  assignedThreads SupportThread[]  @relation("SupportThreadAssignedUser")

  @@index([role])
  @@index([status])
  @@index([authProvider])
  @@index([cpf])
}

model WalletTransaction {
  id          String   @id @default(uuid())
  userId      String
  type        String
  source      String
  sourceId    String?
  amount      Decimal  @db.Decimal(10, 2)
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([source])
}

model TicketCancellation {
  id             String   @id @default(uuid())
  ticketId       String
  orderId        String
  userId         String
  mode           String
  originalAmount Decimal  @db.Decimal(10, 2)
  returnedAmount Decimal  @db.Decimal(10, 2)
  status         String   @default("COMPLETED")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  ticket Ticket @relation(fields: [ticketId], references: [id])
  order  Order  @relation(fields: [orderId], references: [id])
  user   User   @relation(fields: [userId], references: [id])

  @@index([ticketId])
  @@index([orderId])
  @@index([userId])
}

model SupportThread {
  id             String   @id @default(uuid())
  organizerId    String
  eventId        String
  orderId        String?
  customerUserId String?
  customerEmail  String
  customerName   String?
  customerCpf    String?
  subject        String
  status         String   @default("OPEN")
  lastMessageAt  DateTime @default(now())
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  assignedUserId String?

  organizer    Organizer        @relation(fields: [organizerId], references: [id])
  event        Event            @relation(fields: [eventId], references: [id])
  order        Order?           @relation(fields: [orderId], references: [id])
  customerUser User?            @relation("SupportThreadCustomerUser", fields: [customerUserId], references: [id])
  assignedUser User?            @relation("SupportThreadAssignedUser", fields: [assignedUserId], references: [id])
  messages     SupportMessage[]

  @@index([organizerId])
  @@index([eventId])
  @@index([orderId])
  @@index([customerUserId])
  @@index([customerEmail])
  @@index([customerCpf])
  @@index([status])
  @@index([lastMessageAt])
  @@index([assignedUserId])
}

model SupportMessage {
  id           String   @id @default(uuid())
  threadId     String
  senderUserId String?
  senderName   String?
  senderEmail  String?
  senderType   String
  message      String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  thread     SupportThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  senderUser User?         @relation("SupportMessageSender", fields: [senderUserId], references: [id])

  @@index([threadId])
  @@index([senderUserId])
  @@index([senderType])
  @@index([createdAt])
}